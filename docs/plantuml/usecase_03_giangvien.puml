@startuml usecase_03_giangvien

skinparam backgroundColor #FFFFFF
skinparam usecase {
    BackgroundColor #DDEEFF
    BorderColor #4A90D9
    FontName Arial
    FontSize 11
}
skinparam actor {
    BackgroundColor #DDEEFF
    BorderColor #4A90D9
    FontName Arial
    FontSize 11
    FontStyle bold
}
skinparam ArrowColor #333333
skinparam ArrowThickness 1.2
skinparam Shadowing false
skinparam Padding 5
skinparam NodeSep 40
skinparam RankSep 60

left to right direction

actor "Giảng viên" as GV

' ── Nhóm TRÊN Login ──────────────────────────────────────────────────────
together {
    usecase "Xem thông tin\ncá nhân"            as UC_ThongTin
    usecase "Xem lịch dạy\ntheo ngày / tuần"   as UC_LichDay
    usecase "Xem danh sách\nlớp & học viên"     as UC_DsLop
}

' ── TRUNG TÂM ─────────────────────────────────────────────────────────────
usecase "Đăng nhập" as UC_Login

' ── Nhóm DƯỚI Login ──────────────────────────────────────────────────────
together {
    usecase "Điểm danh\nhọc viên"               as UC_DiemDanh
    usecase "Ghi nhận km\nthực hành"            as UC_Km
    usecase "Xem tiến độ\nhọc viên"             as UC_TienDo
    usecase "Báo lỗi xe\nsau thực hành"        as UC_BaoLoi
}

' ── Ép Login nằm giữa ────────────────────────────────────────────────────
UC_DsLop   -[hidden]-> UC_Login
UC_Login   -[hidden]-> UC_DiemDanh

' ── Actor → Use Case (mũi tên liền) ──────────────────────────────────────
GV --> UC_ThongTin
GV --> UC_LichDay
GV --> UC_DsLop
GV --> UC_Login
GV --> UC_DiemDanh
GV --> UC_Km
GV --> UC_TienDo
GV --> UC_BaoLoi

' ── <<include>> đường đứt nét → tất cả chỉ vào Login ────────────────────
UC_ThongTin .> UC_Login : <<include>>
UC_LichDay  .> UC_Login : <<include>>
UC_DsLop    .> UC_Login : <<include>>
UC_DiemDanh .> UC_Login : <<include>>
UC_Km       .> UC_Login : <<include>>
UC_TienDo   .> UC_Login : <<include>>
UC_BaoLoi   .> UC_Login : <<include>>

' ── <<extend>>: Ghi nhận km mở rộng từ Điểm danh ────────────────────────
UC_Km       .> UC_DiemDanh : <<extend>>

@enduml
