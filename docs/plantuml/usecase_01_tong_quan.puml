@startuml usecase_01_tong_quan

skinparam backgroundColor #FFFFFF
skinparam usecase {
    BackgroundColor #DDEEFF
    BorderColor #4A90D9
    FontName Arial
    FontSize 10
}
skinparam actor {
    BackgroundColor #FFFFFF
    BorderColor #4A90D9
    FontName Arial
    FontSize 10
    FontStyle bold
}
skinparam ArrowColor #4A90D9
skinparam ArrowThickness 1
skinparam Shadowing false
skinparam Padding 2
skinparam NodeSep 10
skinparam RankSep 15

left to right direction

actor "Quản trị viên" as Admin

usecase "Đăng nhập hệ thống"                 as UC01
usecase "Quản lý hồ sơ học viên"             as UC02
usecase "Quản lý loại bằng lái\nvà khóa học" as UC03
usecase "Quản lý lớp học"                    as UC04
usecase "Quản lý lịch học"                   as UC05
usecase "Điểm danh học viên"                 as UC06
usecase "Quản lý xe tập lái"                 as UC07
usecase "Báo lỗi xe"                         as UC08
usecase "Quản lý học phí"                    as UC09
usecase "Quản lý thi & kết quả"              as UC10
usecase "Xem lịch dạy\nvà danh sách lớp"    as UC11
usecase "Xem tiến độ học viên"               as UC12
usecase "Đăng ký hồ sơ\ntrực tuyến"         as UC13
usecase "Xem lịch học & tiến độ"             as UC14
usecase "Xem kết quả thi & học phí"          as UC15
usecase "Dashboard thống kê"                 as UC16

actor "Giảng viên" as GV
actor "Học viên"   as HV

Admin --> UC01
Admin --> UC02
Admin --> UC03
Admin --> UC04
Admin --> UC05
Admin --> UC06
Admin --> UC07
Admin --> UC09
Admin --> UC10
Admin --> UC12
Admin --> UC16

UC01 <-- GV
UC06 <-- GV
UC08 <-- GV
UC11 <-- GV
UC12 <-- GV

UC01 <-- HV
UC13 <-- HV
UC14 <-- HV
UC15 <-- HV

@enduml
