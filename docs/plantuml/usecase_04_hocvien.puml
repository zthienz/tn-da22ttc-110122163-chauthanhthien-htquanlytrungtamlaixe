@startuml usecase_04_hocvien

skinparam backgroundColor #FFFFFF
skinparam usecase {
    BackgroundColor #DDEEFF
    BorderColor #4A90D9
    FontName Arial
    FontSize 11
}
skinparam actor {
    BackgroundColor #DDEEFF
    BorderColor #4A90D9
    FontName Arial
    FontSize 11
    FontStyle bold
}
skinparam ArrowColor #333333
skinparam ArrowThickness 1.2
skinparam Shadowing false
skinparam Padding 5
skinparam NodeSep 40
skinparam RankSep 60

left to right direction

actor "Khách"     as Khach
actor "Học viên"  as HV

' ── UC Khách (không cần đăng nhập) ───────────────────────────────────────
together {
    usecase "Xem thông tin\ntrung tâm"          as UC_XemTT
    usecase "Xem loại bằng lái\nvà học phí"     as UC_XemBang
    usecase "Đăng ký hồ sơ\ntrực tuyến"        as UC_DangKy
}

' ── TRUNG TÂM ─────────────────────────────────────────────────────────────
usecase "Đăng nhập" as UC_Login

' ── UC Học viên (sau đăng nhập) ───────────────────────────────────────────
together {
    usecase "Xem lịch học\nsắp tới"             as UC_LichHoc
    usecase "Xem tiến độ\nhọc tập"              as UC_TienDo
    usecase "Xem điều kiện\ndự thi"             as UC_DKThi
    usecase "Xem kết quả thi"                   as UC_KetQua
    usecase "Xem lịch sử\nhọc phí"              as UC_HocPhi
    usecase "Cập nhật thông tin\ncá nhân"       as UC_ThongTin
}

' ── Ép Login nằm giữa ────────────────────────────────────────────────────
UC_DangKy  -[hidden]-> UC_Login
UC_Login   -[hidden]-> UC_LichHoc

' ── Khách → UC (không cần đăng nhập) ─────────────────────────────────────
Khach --> UC_XemTT
Khach --> UC_XemBang
Khach --> UC_DangKy

' ── Học viên → UC (sau đăng nhập) ────────────────────────────────────────
HV --> UC_Login
HV --> UC_LichHoc
HV --> UC_TienDo
HV --> UC_DKThi
HV --> UC_KetQua
HV --> UC_HocPhi
HV --> UC_ThongTin

' ── <<include>> đường đứt nét → tất cả chỉ vào Login ────────────────────
UC_LichHoc  .> UC_Login : <<include>>
UC_TienDo   .> UC_Login : <<include>>
UC_DKThi    .> UC_Login : <<include>>
UC_KetQua   .> UC_Login : <<include>>
UC_HocPhi   .> UC_Login : <<include>>
UC_ThongTin .> UC_Login : <<include>>

' ── <<extend>>: Xem điều kiện dự thi mở rộng từ Xem tiến độ ─────────────
UC_DKThi    .> UC_TienDo : <<extend>>

@enduml
